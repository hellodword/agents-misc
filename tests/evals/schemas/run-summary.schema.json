{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-misc.invalid/evals/run-summary.schema.json",
  "title": "Agent eval run summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "agent",
    "subject",
    "payload_sha256",
    "policy",
    "repeat",
    "preflight",
    "totals",
    "usage",
    "case_results",
    "results",
    "certification",
    "artifacts_dir"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["running", "passed", "failed"] },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "codex" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "reasoning_effort",
        "judge_model",
        "judge_reasoning_effort"
      ],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "reasoning_effort": { "type": "string", "minLength": 1 },
        "judge_model": { "type": "string", "minLength": 1 },
        "judge_reasoning_effort": { "type": "string", "minLength": 1 }
      }
    },
    "payload_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "policy": { "$ref": "#/$defs/policy" },
    "repeat": { "type": "integer", "minimum": 1 },
    "preflight": { "type": "object" },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempts", "passed", "failed"],
      "properties": {
        "attempts": { "type": "integer", "minimum": 1 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      }
    },
    "usage": { "$ref": "#/$defs/usage_summary" },
    "case_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/case_result" }
    },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/result" }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "status", "dimensions", "warnings"],
      "properties": {
        "requested": { "type": "boolean" },
        "status": { "enum": ["not-requested", "passed", "failed"] },
        "dimensions": { "type": "object" },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "artifacts_dir": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "usage_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calls",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "reasoning_output_tokens"
      ],
      "properties": {
        "calls": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "reasoning_output_tokens": { "type": "integer", "minimum": 0 }
      }
    },
    "usage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "judge", "total"],
      "properties": {
        "subject": { "$ref": "#/$defs/usage_counts" },
        "judge": { "$ref": "#/$defs/usage_counts" },
        "total": { "$ref": "#/$defs/usage_counts" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_policy",
        "sandbox_mode",
        "approval_source",
        "sandbox_source"
      ],
      "properties": {
        "approval_policy": { "enum": ["untrusted", "on-request", "never"] },
        "sandbox_mode": {
          "enum": ["read-only", "workspace-write", "danger-full-access"]
        },
        "approval_source": { "type": "string", "minLength": 1 },
        "sandbox_source": { "type": "string", "minLength": 1 }
      }
    },
    "case_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "corpus",
        "passed",
        "route",
        "behavior",
        "baseline",
        "failures"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "corpus": { "enum": ["routing", "skills", "safety"] },
        "passed": { "type": "boolean" },
        "route": { "type": "object" },
        "behavior": { "type": "object" },
        "baseline": { "type": "object" },
        "failures": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "corpus",
        "attempt",
        "status",
        "route",
        "behavior",
        "baseline"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "corpus": { "enum": ["routing", "skills", "safety"] },
        "attempt": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["passed", "failed"] },
        "route": { "type": ["object", "null"] },
        "behavior": { "type": "object" },
        "baseline": { "type": "object" },
        "error": { "type": "string", "minLength": 1 }
      }
    }
  }
}
