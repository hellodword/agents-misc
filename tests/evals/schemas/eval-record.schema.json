{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-misc.invalid/evals/eval-record.schema.json",
  "title": "Agent eval subject case",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "task"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "task": {
      "type": "string",
      "minLength": 1
    }
  }
}
