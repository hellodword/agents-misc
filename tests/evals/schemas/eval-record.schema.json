{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-misc.invalid/evals/eval-record.schema.json",
  "title": "Agent eval record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task",
    "expected_rules",
    "forbidden_rules",
    "expected_skills",
    "forbidden_skills",
    "expected_behavior",
    "behavior_checks"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "expected_rules": {
      "$ref": "#/$defs/rules"
    },
    "forbidden_rules": {
      "$ref": "#/$defs/rules"
    },
    "expected_skills": {
      "$ref": "#/$defs/skills"
    },
    "forbidden_skills": {
      "$ref": "#/$defs/skills"
    },
    "expected_behavior": {
      "type": "string",
      "minLength": 1
    },
    "behavior_checks": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "expected"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "expected": {
            "type": "boolean"
          }
        }
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["expected"],
            "properties": {
              "expected": { "const": true }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": ["expected"],
            "properties": {
              "expected": { "const": false }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "rules": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^\\.agents/rules/[a-z0-9-]+\\.md$"
      }
    },
    "skills": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    }
  }
}
