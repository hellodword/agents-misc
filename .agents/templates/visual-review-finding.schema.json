{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "batch_id": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "finding_id": { "type": "string" },
          "screenshot_id": { "type": "string" },
          "page_or_component": { "type": "string" },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "category": {
            "type": "string",
            "enum": [
              "layout",
              "hierarchy",
              "spacing",
              "alignment",
              "typography",
              "color-contrast",
              "responsive-behavior",
              "i18n-copy",
              "accessibility",
              "state-handling",
              "consistency",
              "visual-polish",
              "possible-bug"
            ]
          },
          "evidence": { "type": "string" },
          "recommendation": { "type": "string" },
          "affected_context": { "type": "string" },
          "duplicate_candidate_id": { "type": ["string", "null"] },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "needs_human_decision": { "type": "boolean" }
        },
        "required": [
          "finding_id",
          "screenshot_id",
          "page_or_component",
          "severity",
          "category",
          "evidence",
          "recommendation",
          "affected_context",
          "duplicate_candidate_id",
          "confidence",
          "needs_human_decision"
        ]
      }
    }
  },
  "required": ["batch_id", "findings"]
}
