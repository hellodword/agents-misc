{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Rules Kit manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "2" },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "rules_schema_version": { "const": "4" },
    "skills_schema_version": { "const": "1" },
    "overlay_discovery_version": { "const": "2" },
    "companion_metadata_version": { "const": "3" }
  },
  "required": [
    "schema_version",
    "name",
    "version",
    "rules_schema_version",
    "skills_schema_version",
    "overlay_discovery_version",
    "companion_metadata_version"
  ]
}
