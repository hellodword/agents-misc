+        cwd: turn_context.cwd.clone(),
+        model: turn_context.model_info.slug.clone(),
+        provider: turn_context.config.model_provider_id.clone(),
+        request_type: failure.context.request_type.to_string(),
+        request_subtype: failure.context.request_subtype.to_string(),
+        endpoint_path: failure.context.endpoint_path.to_string(),
+        retry_attempt: failure.retry_attempt,
+        max_retries: failure.max_retries,
+        will_retry: failure.will_retry,
+        next_retry_attempt: failure.next_retry_attempt,
+        error_retryable: failure.error_retryable,
+        error_kind: failure.error_kind,
+        error_message: failure.error_message,
+        codex_error_info: failure.codex_error_info,
+    };
+    let hooks = sess.hooks();
+    let preview_runs = hooks.preview_request_error(&request);
+    if preview_runs.is_empty() {
+        return;
+    }
+    emit_hook_started_events(sess, turn_context, preview_runs).await;
+
+    let sess = Arc::clone(sess);
+    let turn_context = Arc::clone(turn_context);
+    let _hook_task = tokio::spawn(async move {
+        let outcome = hooks.run_request_error(request).await;
+        emit_hook_completed_events(&sess, &turn_context, outcome.hook_events).await;
+    });
