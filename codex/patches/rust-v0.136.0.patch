+#[test]
+fn accepts_openai_network_overrides() {
+    let cfg = toml::from_str::<ConfigToml>(
+        r#"
+[model_providers.openai]
+request_max_retries = 6
+stream_max_retries = 7
+stream_idle_timeout_ms = 8000
+websocket_connect_timeout_ms = 9000
+compact_request_timeout_ms = 10000
+"#,
+    )
+    .expect("OpenAI network overrides should deserialize");
+
+    let provider = cfg
+        .model_providers
+        .get("openai")
+        .expect("OpenAI override should be present");
+    assert_eq!(provider.request_max_retries, Some(6));
+    assert_eq!(provider.stream_max_retries, Some(7));
+    assert_eq!(provider.stream_idle_timeout_ms, Some(8_000));
+    assert_eq!(provider.websocket_connect_timeout_ms, Some(9_000));
+    assert_eq!(provider.compact_request_timeout_ms, Some(10_000));
+}
+
+#[tokio::test]
+async fn load_config_applies_openai_network_overrides() {
+    let cfg = toml::from_str::<ConfigToml>(
+        r#"
+model_provider = "openai"
+
+[model_providers.openai]
+request_max_retries = 6
+stream_max_retries = 7
+stream_idle_timeout_ms = 8000
+websocket_connect_timeout_ms = 9000
+compact_request_timeout_ms = 10000
+"#,
+    )
+    .expect("OpenAI network overrides should deserialize");
+
+    let config = Config::load_from_base_config_with_overrides(
+        cfg,
+        ConfigOverrides::default(),
+        tempdir().expect("tempdir").abs(),
+    )
+    .await
+    .expect("load config");
+
+    assert_eq!(config.model_provider_id, "openai");
+    assert_eq!(config.model_provider.request_max_retries, Some(6));
+    assert_eq!(config.model_provider.stream_max_retries, Some(7));
+    assert_eq!(config.model_provider.stream_idle_timeout_ms, Some(8_000));
+    assert_eq!(
+        config.model_provider.websocket_connect_timeout_ms,
+        Some(9_000)
+    );
+    assert_eq!(
+        config.model_provider.compact_request_timeout(),
+        Some(Duration::from_millis(10_000))
+    );
+}
