+#[test]
+fn test_merge_configured_model_providers_applies_openai_network_overrides() {
+    let configured_model_providers = std::collections::HashMap::from([(
+        OPENAI_PROVIDER_ID.to_string(),
+        ModelProviderInfo {
+            request_max_retries: Some(8),
+            stream_max_retries: Some(10),
+            stream_idle_timeout_ms: Some(600_000),
+            websocket_connect_timeout_ms: Some(30_000),
+            compact_request_timeout_ms: Some(120_000),
+            ..ModelProviderInfo::default()
+        },
+    )]);
+
+    let mut expected = built_in_model_providers(/*openai_base_url*/ None);
+    let openai = expected
+        .get_mut(OPENAI_PROVIDER_ID)
+        .expect("OpenAI provider should be built in");
+    openai.request_max_retries = Some(8);
+    openai.stream_max_retries = Some(10);
+    openai.stream_idle_timeout_ms = Some(600_000);
+    openai.websocket_connect_timeout_ms = Some(30_000);
+    openai.compact_request_timeout_ms = Some(120_000);
+
+    assert_eq!(
+        merge_configured_model_providers(
+            built_in_model_providers(/*openai_base_url*/ None),
+            configured_model_providers,
+        ),
+        Ok(expected)
+    );
+}
