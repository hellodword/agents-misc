+#[test]
+fn accepts_openai_network_overrides() {
+    let cfg = toml::from_str::<ConfigToml>(
+        r#"
+[model_providers.openai]
+stream_idle_timeout_ms = 600000
+stream_max_retries = 10
+request_max_retries = 8
+websocket_connect_timeout_ms = 30000
+compact_request_timeout_ms = 120000
+"#,
+    )
+    .expect("OpenAI network overrides should deserialize");
+
+    let openai = cfg
+        .model_providers
+        .get("openai")
+        .expect("OpenAI override should be present");
+    assert_eq!(openai.stream_idle_timeout_ms, Some(600_000));
+    assert_eq!(openai.stream_max_retries, Some(10));
+    assert_eq!(openai.request_max_retries, Some(8));
+    assert_eq!(openai.websocket_connect_timeout_ms, Some(30_000));
+    assert_eq!(openai.compact_request_timeout_ms, Some(120_000));
+}
+
+#[tokio::test]
+async fn load_config_default_openai_applies_network_overrides() {
+    let cfg = toml::from_str::<ConfigToml>(
+        r#"
+[model_providers.openai]
+stream_idle_timeout_ms = 600000
+stream_max_retries = 10
+request_max_retries = 8
+websocket_connect_timeout_ms = 30000
+compact_request_timeout_ms = 120000
+"#,
+    )
+    .expect("OpenAI network overrides should deserialize");
+
+    let config = Config::load_from_base_config_with_overrides(
+        cfg,
+        ConfigOverrides::default(),
+        tempdir().expect("tempdir").abs(),
+    )
+    .await
+    .expect("load config");
+
+    assert_eq!(config.model_provider_id, "openai");
+    assert_eq!(config.model_provider.stream_idle_timeout_ms, Some(600_000));
+    assert_eq!(config.model_provider.stream_max_retries, Some(10));
+    assert_eq!(config.model_provider.request_max_retries, Some(8));
+    assert_eq!(
+        config.model_provider.websocket_connect_timeout_ms,
+        Some(30_000)
+    );
+    assert_eq!(
+        config.model_provider.compact_request_timeout_ms,
+        Some(120_000)
+    );
+    assert!(config.model_provider.requires_openai_auth);
+    assert!(config.model_provider.supports_websockets);
+}
+
+#[tokio::test]
+async fn load_config_rejects_unsupported_openai_overrides() {
+    let cfg = toml::from_str::<ConfigToml>(
+        r#"
+[model_providers.openai]
+name = "Custom OpenAI"
+compact_request_timeout_ms = 120000
+"#,
+    )
+    .expect("OpenAI unsupported overrides should deserialize");
+
+    let err = Config::load_from_base_config_with_overrides(
+        cfg,
+        ConfigOverrides::default(),
+        tempdir().expect("tempdir").abs(),
+    )
+    .await
+    .unwrap_err();
+
+    assert_eq!(err.kind(), std::io::ErrorKind::InvalidData);
+    assert!(err.to_string().contains(
+        "model_providers.openai only supports changing `stream_idle_timeout_ms`, \
+`stream_max_retries`, `request_max_retries`, `websocket_connect_timeout_ms`, and \
+`compact_request_timeout_ms`; other non-default provider fields are not supported"
+    ));
+}
