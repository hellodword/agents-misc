diff --git a/codex-rs/model-provider-info/src/openai_overrides.rs b/codex-rs/model-provider-info/src/openai_overrides.rs
new file mode 100644
index 0000000000..e3069a98bf
--- /dev/null
+++ b/codex-rs/model-provider-info/src/openai_overrides.rs
@@ -0,0 +1,39 @@
+use crate::ModelProviderInfo;
+
+pub(crate) const OPENAI_PROVIDER_OVERRIDE_ERROR: &str =
+    "model_providers.openai only supports changing `stream_idle_timeout_ms`, \
+`stream_max_retries`, `request_max_retries`, `websocket_connect_timeout_ms`, and \
+`compact_request_timeout_ms`; other non-default provider fields are not supported";
+
+pub(crate) fn apply_openai_network_overrides(
+    built_in_provider: &mut ModelProviderInfo,
+    provider_override: &mut ModelProviderInfo,
+) -> Result<(), String> {
+    let request_max_retries = provider_override.request_max_retries.take();
+    let stream_max_retries = provider_override.stream_max_retries.take();
+    let stream_idle_timeout_ms = provider_override.stream_idle_timeout_ms.take();
+    let websocket_connect_timeout_ms = provider_override.websocket_connect_timeout_ms.take();
+    let compact_request_timeout_ms = provider_override.compact_request_timeout_ms.take();
+
+    if *provider_override != ModelProviderInfo::default() {
+        return Err(OPENAI_PROVIDER_OVERRIDE_ERROR.to_string());
+    }
+
+    if request_max_retries.is_some() {
+        built_in_provider.request_max_retries = request_max_retries;
+    }
+    if stream_max_retries.is_some() {
+        built_in_provider.stream_max_retries = stream_max_retries;
+    }
+    if stream_idle_timeout_ms.is_some() {
+        built_in_provider.stream_idle_timeout_ms = stream_idle_timeout_ms;
+    }
+    if websocket_connect_timeout_ms.is_some() {
+        built_in_provider.websocket_connect_timeout_ms = websocket_connect_timeout_ms;
+    }
+    if compact_request_timeout_ms.is_some() {
+        built_in_provider.compact_request_timeout_ms = compact_request_timeout_ms;
+    }
+
+    Ok(())
+}
