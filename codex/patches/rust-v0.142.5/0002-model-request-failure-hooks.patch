diff --git a/codex-rs/hooks/src/events/model_request.rs b/codex-rs/hooks/src/events/model_request.rs
new file mode 100644
index 0000000..83cdce7
--- /dev/null
+++ b/codex-rs/hooks/src/events/model_request.rs
@@ -0,0 +1,316 @@
+use std::path::PathBuf;
+
+use codex_protocol::ThreadId;
+use codex_protocol::protocol::HookCompletedEvent;
+use codex_protocol::protocol::HookEventName;
+use codex_protocol::protocol::HookOutputEntry;
+use codex_protocol::protocol::HookOutputEntryKind;
+use codex_protocol::protocol::HookRunStatus;
+use codex_protocol::protocol::HookRunSummary;
+use codex_utils_absolute_path::AbsolutePathBuf;
+use serde_json::Value;
+
+use super::common;
+use crate::engine::CommandShell;
+use crate::engine::ConfiguredHandler;
+use crate::engine::command_runner::CommandRunResult;
+use crate::engine::dispatcher;
+use crate::engine::output_parser;
+use crate::schema::AbnormalStopCommandInput;
+use crate::schema::NullableString;
+use crate::schema::RequestErrorCommandInput;
+
+#[derive(Debug, Clone)]
+pub struct RequestErrorRequest {
+    pub session_id: ThreadId,
+    pub turn_id: String,
+    pub transcript_path: Option<PathBuf>,
+    pub cwd: AbsolutePathBuf,
+    pub model: String,
+    pub provider: String,
+    pub request_type: String,
+    pub request_subtype: String,
+    pub endpoint_path: String,
+    pub retry_attempt: u64,
+    pub max_retries: u64,
+    pub will_retry: bool,
+    pub next_retry_attempt: Option<u64>,
+    pub error_retryable: bool,
+    pub error_kind: String,
+    pub error_message: String,
+    pub codex_error_info: Value,
+}
+
+#[derive(Debug, Clone)]
+pub struct AbnormalStopRequest {
+    pub session_id: ThreadId,
+    pub turn_id: String,
+    pub transcript_path: Option<PathBuf>,
+    pub cwd: AbsolutePathBuf,
+    pub model: String,
+    pub provider: String,
+    pub request_type: String,
+    pub request_subtype: String,
+    pub endpoint_path: String,
+    pub retry_attempt: u64,
+    pub max_retries: u64,
+    pub error_kind: String,
+    pub error_message: String,
+    pub codex_error_info: Value,
+}
+
+#[derive(Debug, Default)]
+pub struct NotificationHookOutcome {
+    pub hook_events: Vec<HookCompletedEvent>,
+}
+
+pub(crate) fn preview_request_error(
+    handlers: &[ConfiguredHandler],
+    _request: &RequestErrorRequest,
+) -> Vec<HookRunSummary> {
+    preview(handlers, HookEventName::RequestError)
+}
+
+pub(crate) async fn run_request_error(
+    handlers: &[ConfiguredHandler],
+    shell: &CommandShell,
+    request: RequestErrorRequest,
+) -> NotificationHookOutcome {
+    let input_json = match serde_json::to_string(&RequestErrorCommandInput {
+        session_id: request.session_id.to_string(),
+        turn_id: request.turn_id.clone(),
+        transcript_path: NullableString::from_path(request.transcript_path),
+        cwd: request.cwd.display().to_string(),
+        hook_event_name: "RequestError".to_string(),
+        model: request.model,
+        provider: request.provider,
+        request_type: request.request_type,
+        request_subtype: request.request_subtype,
+        endpoint_path: request.endpoint_path,
+        retry_attempt: request.retry_attempt,
+        max_retries: request.max_retries,
+        will_retry: request.will_retry,
+        next_retry_attempt: request.next_retry_attempt,
+        error_retryable: request.error_retryable,
+        error_kind: request.error_kind,
+        error_message: request.error_message,
+        codex_error_info: request.codex_error_info,
+    }) {
+        Ok(input_json) => input_json,
+        Err(error) => {
+            let matched = select(handlers, HookEventName::RequestError);
+            return NotificationHookOutcome {
+                hook_events: common::serialization_failure_hook_events(
+                    matched,
+                    Some(request.turn_id),
+                    format!("failed to serialize request error hook input: {error}"),
+                ),
+            };
+        }
+    };
+    run_notification(
+        handlers,
+        shell,
+        HookEventName::RequestError,
+        input_json,
+        request.cwd,
+        Some(request.turn_id),
+        parse_request_error_completed,
+    )
+    .await
+}
+
+pub(crate) fn preview_abnormal_stop(
+    handlers: &[ConfiguredHandler],
+    _request: &AbnormalStopRequest,
+) -> Vec<HookRunSummary> {
+    preview(handlers, HookEventName::AbnormalStop)
+}
+
+pub(crate) async fn run_abnormal_stop(
+    handlers: &[ConfiguredHandler],
+    shell: &CommandShell,
+    request: AbnormalStopRequest,
+) -> NotificationHookOutcome {
+    let input_json = match serde_json::to_string(&AbnormalStopCommandInput {
+        session_id: request.session_id.to_string(),
+        turn_id: request.turn_id.clone(),
+        transcript_path: NullableString::from_path(request.transcript_path),
+        cwd: request.cwd.display().to_string(),
+        hook_event_name: "AbnormalStop".to_string(),
+        model: request.model,
+        provider: request.provider,
+        reason: "request_error".to_string(),
+        request_type: request.request_type,
+        request_subtype: request.request_subtype,
+        endpoint_path: request.endpoint_path,
+        retry_attempt: request.retry_attempt,
+        max_retries: request.max_retries,
+        error_kind: request.error_kind,
+        error_message: request.error_message,
+        codex_error_info: request.codex_error_info,
+    }) {
+        Ok(input_json) => input_json,
+        Err(error) => {
+            let matched = select(handlers, HookEventName::AbnormalStop);
+            return NotificationHookOutcome {
+                hook_events: common::serialization_failure_hook_events(
+                    matched,
+                    Some(request.turn_id),
+                    format!("failed to serialize abnormal stop hook input: {error}"),
+                ),
+            };
+        }
+    };
+    run_notification(
+        handlers,
+        shell,
+        HookEventName::AbnormalStop,
+        input_json,
+        request.cwd,
+        Some(request.turn_id),
+        parse_abnormal_stop_completed,
+    )
+    .await
+}
+
+fn preview(handlers: &[ConfiguredHandler], event_name: HookEventName) -> Vec<HookRunSummary> {
+    select(handlers, event_name)
+        .into_iter()
+        .map(|handler| dispatcher::running_summary(&handler))
+        .collect()
+}
+
+fn select(handlers: &[ConfiguredHandler], event_name: HookEventName) -> Vec<ConfiguredHandler> {
+    dispatcher::select_handlers(handlers, event_name, /*matcher_input*/ None)
+}
+
+async fn run_notification(
+    handlers: &[ConfiguredHandler],
+    shell: &CommandShell,
+    event_name: HookEventName,
+    input_json: String,
+    cwd: AbsolutePathBuf,
+    turn_id: Option<String>,
+    parse: fn(
+        &ConfiguredHandler,
+        CommandRunResult,
+        Option<String>,
+    ) -> dispatcher::ParsedHandler<()>,
+) -> NotificationHookOutcome {
+    let matched = select(handlers, event_name);
+    if matched.is_empty() {
+        return NotificationHookOutcome::default();
+    }
+
+    let results =
+        dispatcher::execute_handlers(shell, matched, input_json, cwd.as_path(), turn_id, parse)
+            .await;
+
+    NotificationHookOutcome {
+        hook_events: results.into_iter().map(|result| result.completed).collect(),
+    }
+}
+
+fn parse_request_error_completed(
+    handler: &ConfiguredHandler,
+    run_result: CommandRunResult,
+    turn_id: Option<String>,
+) -> dispatcher::ParsedHandler<()> {
+    parse_notification_completed(
+        handler,
+        run_result,
+        turn_id,
+        "RequestError",
+        output_parser::parse_request_error,
+    )
+}
+
+fn parse_abnormal_stop_completed(
+    handler: &ConfiguredHandler,
+    run_result: CommandRunResult,
+    turn_id: Option<String>,
+) -> dispatcher::ParsedHandler<()> {
+    parse_notification_completed(
+        handler,
+        run_result,
+        turn_id,
+        "AbnormalStop",
+        output_parser::parse_abnormal_stop,
+    )
+}
+
+fn parse_notification_completed(
+    handler: &ConfiguredHandler,
+    run_result: CommandRunResult,
+    turn_id: Option<String>,
+    event_label: &'static str,
+    parse_output: fn(&str) -> Option<output_parser::StatelessHookOutput>,
+) -> dispatcher::ParsedHandler<()> {
+    let mut entries = Vec::new();
+    let mut status = HookRunStatus::Completed;
+
+    match run_result.error.as_deref() {
+        Some(error) => {
+            status = HookRunStatus::Failed;
+            entries.push(HookOutputEntry {
+                kind: HookOutputEntryKind::Error,
+                text: error.to_string(),
+            });
+        }
+        None => match run_result.exit_code {
+            Some(0) => {
+                let trimmed_stdout = run_result.stdout.trim();
+                if trimmed_stdout.is_empty() {
+                } else if let Some(parsed) = parse_output(&run_result.stdout) {
+                    if let Some(system_message) = parsed.universal.system_message {
+                        entries.push(HookOutputEntry {
+                            kind: HookOutputEntryKind::Warning,
+                            text: system_message,
+                        });
+                    }
+                    let _ = parsed.universal.suppress_output;
+                    let _ = parsed.universal.continue_processing;
+                    let _ = parsed.universal.stop_reason;
+                    if let Some(invalid_reason) = parsed.invalid_reason {
+                        status = HookRunStatus::Failed;
+                        entries.push(HookOutputEntry {
+                            kind: HookOutputEntryKind::Error,
+                            text: invalid_reason,
+                        });
+                    }
+                } else if output_parser::looks_like_json(&run_result.stdout) {
+                    status = HookRunStatus::Failed;
+                    entries.push(HookOutputEntry {
+                        kind: HookOutputEntryKind::Error,
+                        text: format!("hook returned invalid {event_label} hook JSON output"),
+                    });
+                }
+            }
+            Some(code) => {
+                status = HookRunStatus::Failed;
+                entries.push(HookOutputEntry {
+                    kind: HookOutputEntryKind::Error,
+                    text: common::trimmed_non_empty(&run_result.stderr)
+                        .unwrap_or_else(|| format!("hook exited with code {code}")),
+                });
+            }
+            None => {
+                status = HookRunStatus::Failed;
+                entries.push(HookOutputEntry {
+                    kind: HookOutputEntryKind::Error,
+                    text: "hook process terminated without an exit code".to_string(),
+                });
+            }
+        },
+    }
+
+    dispatcher::ParsedHandler {
+        completed: HookCompletedEvent {
+            turn_id,
+            run: dispatcher::completed_summary(handler, &run_result, status, entries),
+        },
+        data: (),
+        completion_order: 0,
+    }
+}
