+        poll_interval_ms = 999
+        max_output_tokens = 999
+
+        [[terminal_wait.commands]]
+        pattern = "cargo"
+        cwd_pattern = "/repo"
+        mode = "long_poll"
+        poll_interval_ms = 111
+        max_output_tokens = 111
+
+        [[terminal_wait.commands]]
+        pattern = "cargo"
+        mode = "long_poll"
+        poll_interval_ms = 222
+        max_output_tokens = 222
+        "#,
+    );
+
+    let rule = terminal_wait_rule(&manager, "cargo test", "/repo/project", /*tty*/ false);
+    assert_eq!(
+        rule.mode,
+        TerminalWaitMode::LongPoll {
+            poll_interval_ms: 111
+        }
+    );
+    assert_eq!(rule.max_output_tokens, Some(111));
+}
