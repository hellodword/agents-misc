+fn terminal_wait_manager(toml: &str) -> UnifiedExecProcessManager {
+    let config: ConfigToml = toml::from_str(toml).expect("terminal_wait config should parse");
+    UnifiedExecProcessManager::new_with_terminal_wait(
+        crate::unified_exec::DEFAULT_MAX_BACKGROUND_TERMINAL_TIMEOUT_MS,
+        config.terminal_wait,
+    )
+}
+
+fn terminal_wait_rule(
+    manager: &UnifiedExecProcessManager,
+    command: &str,
+    cwd: &str,
+    tty: bool,
+) -> Arc<TerminalWaitCommandRule> {
+    manager
+        .terminal_wait_rules
+        .matching_rule(command, cwd, tty)
+        .expect("rule should match")
+}
+
+fn terminal_wait_limit_ms(start: Instant, limit: OutputWaitLimit) -> Option<u64> {
+    match limit {
+        OutputWaitLimit::Until(deadline) => Some(deadline.duration_since(start).as_millis() as u64),
+        OutputWaitLimit::Infinite => None,
+    }
+}
+
+#[test]
