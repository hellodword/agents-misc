+#[derive(Clone, Copy)]
+pub(super) struct TerminalWaitSnapshot {
+    epoch: u64,
+}
+
+#[derive(Default)]
+struct TerminalWaitLeases {
+    states: StdMutex<HashMap<String, TerminalWaitLeaseState>>,
+}
+
+struct TerminalWaitLeaseState {
+    active: usize,
+    epoch: u64,
+    consumed_epoch: u64,
+    pending_decisions: HashSet<String>,
+    notify: Arc<Notify>,
+}
+
+pub(crate) struct TerminalWaitLease {
+    leases: Arc<TerminalWaitLeases>,
+    cell_id: String,
+}
+
+struct TerminalWaitDecision {
+    leases: Arc<TerminalWaitLeases>,
+    cell_id: String,
+    runtime_tool_call_id: String,
+}
+
+impl TerminalWaitLeases {
+    fn acquire(self: &Arc<Self>, cell_id: &str) -> TerminalWaitLease {
+        let mut states = self
+            .states
+            .lock()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        let state = states
+            .entry(cell_id.to_string())
+            .or_insert_with(|| TerminalWaitLeaseState {
+                active: 0,
+                epoch: 0,
+                consumed_epoch: 0,
+                pending_decisions: HashSet::new(),
+                notify: Arc::new(Notify::new()),
+            });
+        state.active = state.active.saturating_add(1);
+        state.epoch = state.epoch.wrapping_add(1);
+        drop(states);
+        TerminalWaitLease {
+            leases: Arc::clone(self),
+            cell_id: cell_id.to_string(),
+        }
+    }
+
+    fn begin_decision(
+        self: &Arc<Self>,
+        cell_id: &str,
+        runtime_tool_call_id: &str,
+    ) -> TerminalWaitDecision {
+        let mut states = self
+            .states
+            .lock()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        let state = states
+            .entry(cell_id.to_string())
+            .or_insert_with(|| TerminalWaitLeaseState {
+                active: 0,
+                epoch: 0,
+                consumed_epoch: 0,
+                pending_decisions: HashSet::new(),
+                notify: Arc::new(Notify::new()),
+            });
+        state
+            .pending_decisions
+            .insert(runtime_tool_call_id.to_string());
+        drop(states);
+        TerminalWaitDecision {
+            leases: Arc::clone(self),
+            cell_id: cell_id.to_string(),
+            runtime_tool_call_id: runtime_tool_call_id.to_string(),
+        }
+    }
+
+    fn resolve_decision(&self, cell_id: &str, runtime_tool_call_id: &str) {
+        let notify = {
+            let mut states = self
+                .states
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner);
+            let Some(state) = states.get_mut(cell_id) else {
+                return;
+            };
+            if !state.pending_decisions.remove(runtime_tool_call_id) {
+                return;
+            }
+            Arc::clone(&state.notify)
+        };
+        notify.notify_waiters();
+    }
+
+    fn snapshot(&self, cell_id: &str) -> TerminalWaitSnapshot {
+        let states = self
+            .states
+            .lock()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        TerminalWaitSnapshot {
+            epoch: states.get(cell_id).map_or(0, |state| state.consumed_epoch),
+        }
+    }
+
+    fn should_absorb(&self, cell_id: &str, snapshot: TerminalWaitSnapshot) -> bool {
+        let states = self
+            .states
+            .lock()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        states
+            .get(cell_id)
+            .is_some_and(|state| state.active > 0 || state.epoch != snapshot.epoch)
+    }
+
+    async fn wait_until_idle_and_consume(&self, cell_id: &str) -> TerminalWaitSnapshot {
+        loop {
+            let notify = {
+                let mut states = self
+                    .states
+                    .lock()
+                    .unwrap_or_else(std::sync::PoisonError::into_inner);
+                let Some(state) = states.get_mut(cell_id) else {
+                    return TerminalWaitSnapshot { epoch: 0 };
+                };
+                if state.active == 0 {
+                    state.consumed_epoch = state.epoch;
+                    return TerminalWaitSnapshot {
+                        epoch: state.consumed_epoch,
+                    };
+                }
+                Arc::clone(&state.notify)
+            };
+            let notified = notify.notified();
+            if self
+                .states
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner)
+                .get(cell_id)
+                .is_none_or(|state| state.active == 0)
+            {
+                continue;
+            }
+            notified.await;
+        }
+    }
+
+    async fn wait_until_decided(&self, cell_id: &str) {
+        loop {
+            let notify = {
+                let states = self
+                    .states
+                    .lock()
+                    .unwrap_or_else(std::sync::PoisonError::into_inner);
+                let Some(state) = states.get(cell_id) else {
+                    return;
+                };
+                if state.pending_decisions.is_empty() {
+                    return;
+                }
+                Arc::clone(&state.notify)
+            };
+            let notified = notify.notified();
+            if self
+                .states
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner)
+                .get(cell_id)
+                .is_none_or(|state| state.pending_decisions.is_empty())
+            {
+                return;
+            }
+            notified.await;
+        }
+    }
+
+    fn clear(&self, cell_id: &str) {
+        let removed = self
+            .states
+            .lock()
+            .unwrap_or_else(std::sync::PoisonError::into_inner)
+            .remove(cell_id);
+        if let Some(state) = removed {
+            state.notify.notify_waiters();
+        }
+    }
+}
+
+impl Drop for TerminalWaitLease {
+    fn drop(&mut self) {
+        let notify = {
+            let mut states = self
+                .leases
+                .states
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner);
+            let Some(state) = states.get_mut(&self.cell_id) else {
+                return;
+            };
+            state.active = state.active.saturating_sub(1);
+            Arc::clone(&state.notify)
+        };
+        notify.notify_waiters();
+    }
+}
+
+impl Drop for TerminalWaitDecision {
+    fn drop(&mut self) {
+        self.leases
+            .resolve_decision(&self.cell_id, &self.runtime_tool_call_id);
+    }
+}
+
+pub(super) async fn absorb_terminal_wait_yields(
+    exec: &ExecContext,
+    mut response: RuntimeResponse,
+    yield_time_ms: u64,
+    mut snapshot: TerminalWaitSnapshot,
+) -> Result<RuntimeResponse, String> {
+    let mut buffered_items = Vec::new();
+    loop {
+        match response {
+            RuntimeResponse::Yielded {
+                cell_id,
+                mut content_items,
+                reason: codex_code_mode::YieldReason::Timer,
+            } => {
+                let service = &exec.session.services.code_mode_service;
+                service.wait_for_terminal_wait_decisions(&cell_id).await;
+                if !service.should_absorb_timer_yield(&cell_id, snapshot) {
+                    content_items.splice(0..0, buffered_items);
+                    return Ok(RuntimeResponse::Yielded {
+                        cell_id,
+                        content_items,
+                        reason: codex_code_mode::YieldReason::Timer,
+                    });
+                }
+                buffered_items.append(&mut content_items);
+                snapshot = service.wait_for_terminal_wait_release(&cell_id).await;
+                response = service
