@@ -0,0 +1,290 @@
+use regex_lite::Regex;
+use schemars::JsonSchema;
+use serde::Deserialize;
+use serde::Deserializer;
+use serde::Serialize;
+use serde::de::Error as SerdeError;
+
+#[derive(Serialize, Deserialize, Debug, Clone, Default, PartialEq, Eq, JsonSchema)]
+#[serde(deny_unknown_fields)]
+#[schemars(deny_unknown_fields)]
+pub struct TerminalWaitToml {
+    #[serde(default)]
+    pub commands: Vec<TerminalWaitCommandToml>,
+}
+
+#[derive(Serialize, Debug, Clone, PartialEq, Eq, JsonSchema)]
+#[schemars(deny_unknown_fields)]
+pub struct TerminalWaitCommandToml {
+    pub pattern: String,
+    pub mode: TerminalWaitModeToml,
+    pub name: Option<String>,
+    #[serde(default = "default_true")]
+    pub enabled: bool,
+    pub cwd_pattern: Option<String>,
+    #[serde(default)]
+    pub allow_tty: bool,
+    pub max_output_tokens: Option<usize>,
+    pub wait_timeout_ms: Option<u64>,
+    pub poll_interval_ms: Option<u64>,
+}
+
+#[derive(Serialize, Deserialize, Debug, Clone, Copy, PartialEq, Eq, JsonSchema)]
+#[serde(rename_all = "snake_case")]
+pub enum TerminalWaitModeToml {
+    WaitUntilExit,
+    LongPoll,
+}
+
+const fn default_true() -> bool {
+    true
+}
+
+impl<'de> Deserialize<'de> for TerminalWaitCommandToml {
+    fn deserialize<D>(deserializer: D) -> Result<Self, D::Error>
+    where
+        D: Deserializer<'de>,
+    {
+        #[derive(Deserialize)]
+        #[serde(deny_unknown_fields)]
+        struct RawTerminalWaitCommandToml {
+            pattern: String,
+            mode: TerminalWaitModeToml,
+            name: Option<String>,
+            #[serde(default = "default_true")]
+            enabled: bool,
+            cwd_pattern: Option<String>,
+            #[serde(default)]
+            allow_tty: bool,
+            max_output_tokens: Option<usize>,
+            wait_timeout_ms: Option<u64>,
+            poll_interval_ms: Option<u64>,
+        }
+
+        let raw = RawTerminalWaitCommandToml::deserialize(deserializer)?;
+        validate_regex("pattern", &raw.pattern).map_err(D::Error::custom)?;
+        if let Some(cwd_pattern) = raw.cwd_pattern.as_deref() {
+            validate_regex("cwd_pattern", cwd_pattern).map_err(D::Error::custom)?;
+        }
+        if raw.max_output_tokens == Some(0) {
+            return Err(D::Error::custom("max_output_tokens must be greater than 0"));
+        }
+
+        match raw.mode {
+            TerminalWaitModeToml::WaitUntilExit => {
+                if raw.wait_timeout_ms == Some(0) {
+                    return Err(D::Error::custom("wait_timeout_ms must be greater than 0"));
+                }
+                if raw.poll_interval_ms.is_some() {
+                    return Err(D::Error::custom(
+                        "poll_interval_ms is not supported when mode is wait_until_exit",
+                    ));
+                }
+            }
+            TerminalWaitModeToml::LongPoll => {
+                let Some(poll_interval_ms) = raw.poll_interval_ms else {
+                    return Err(D::Error::custom(
+                        "poll_interval_ms is required when mode is long_poll",
+                    ));
+                };
+                if poll_interval_ms == 0 {
+                    return Err(D::Error::custom("poll_interval_ms must be greater than 0"));
+                }
+                if raw.wait_timeout_ms.is_some() {
+                    return Err(D::Error::custom(
+                        "wait_timeout_ms is not supported when mode is long_poll",
+                    ));
+                }
+            }
+        }
+
+        Ok(Self {
+            pattern: raw.pattern,
+            mode: raw.mode,
+            name: raw.name,
+            enabled: raw.enabled,
+            cwd_pattern: raw.cwd_pattern,
+            allow_tty: raw.allow_tty,
+            max_output_tokens: raw.max_output_tokens,
+            wait_timeout_ms: raw.wait_timeout_ms,
+            poll_interval_ms: raw.poll_interval_ms,
+        })
+    }
+}
+
+fn validate_regex(field: &str, pattern: &str) -> Result<(), String> {
+    Regex::new(pattern)
+        .map(|_| ())
+        .map_err(|err| format!("{field} is not a valid regex-lite pattern: {err}"))
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::config_toml::ConfigToml;
+
+    #[test]
+    fn terminal_wait_deserializes_command_defaults() {
+        let config: ConfigToml = toml::from_str(
+            r#"
+            [terminal_wait]
+
+            [[terminal_wait.commands]]
+            pattern = "cargo test"
+            mode = "wait_until_exit"
+            "#,
+        )
+        .expect("terminal_wait should parse");
+
+        let command = &config
+            .terminal_wait
+            .expect("terminal_wait should be set")
+            .commands[0];
+        assert_eq!(command.pattern, "cargo test");
+        assert_eq!(command.mode, TerminalWaitModeToml::WaitUntilExit);
+        assert!(command.enabled);
+        assert!(!command.allow_tty);
+        assert_eq!(command.wait_timeout_ms, None);
+    }
+
+    #[test]
