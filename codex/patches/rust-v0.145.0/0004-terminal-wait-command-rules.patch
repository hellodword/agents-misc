+                r#"
+                [terminal_wait]
+
+                [[terminal_wait.commands]]
+                pattern = "cargo"
+                mode = "wait_until_exit"
+                poll_interval_ms = 1000
+                "#,
+                "poll_interval_ms is not supported",
+            ),
+            (
+                r#"
+                [terminal_wait]
+
+                [[terminal_wait.commands]]
+                pattern = "cargo"
+                mode = "long_poll"
+                "#,
