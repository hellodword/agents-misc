+            name = "cargo"
+            pattern = "cargo test"
+            mode = "long_poll"
+            cwd_pattern = "/repo"
+            enabled = false
+            allow_tty = true
+            poll_interval_ms = 60000
+            max_output_tokens = 2000
+            "#,
+        )
+        .expect("terminal_wait should parse");
+
+        let command = &config
+            .terminal_wait
+            .expect("terminal_wait should be set")
+            .commands[0];
+        assert_eq!(command.name.as_deref(), Some("cargo"));
+        assert_eq!(command.mode, TerminalWaitModeToml::LongPoll);
+        assert_eq!(command.cwd_pattern.as_deref(), Some("/repo"));
+        assert!(!command.enabled);
+        assert!(command.allow_tty);
+        assert_eq!(command.poll_interval_ms, Some(60000));
+        assert_eq!(command.max_output_tokens, Some(2000));
+    }
