+#[test]
+fn terminal_wait_max_output_tokens_overrides_tool_request() {
+    let manager = terminal_wait_manager(
+        r#"
+        [terminal_wait]
+
+        [[terminal_wait.commands]]
+        pattern = "cargo"
+        mode = "long_poll"
+        poll_interval_ms = 45000
+        max_output_tokens = 123
+        "#,
+    );
+    let rule = terminal_wait_rule(&manager, "cargo test", "/repo", /*tty*/ false);
+
+    assert_eq!(
+        terminal_wait_max_output_tokens(Some(&rule), Some(456)),
+        Some(123)
+    );
+    assert_eq!(terminal_wait_max_output_tokens(None, Some(456)), Some(456));
+}
