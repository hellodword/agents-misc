+#[tokio::test]
+async fn terminal_wait_infinite_collect_exits_on_cancellation() {
+    let output_buffer = Arc::new(tokio::sync::Mutex::new(HeadTailBuffer::default()));
+    let output_notify = Arc::new(Notify::new());
+    let output_closed = Arc::new(AtomicBool::new(false));
+    let output_closed_notify = Arc::new(Notify::new());
+    let cancellation_token = CancellationToken::new();
+
+    tokio::spawn({
+        let output_closed = Arc::clone(&output_closed);
+        let output_closed_notify = Arc::clone(&output_closed_notify);
+        let cancellation_token = cancellation_token.clone();
+        async move {
+            tokio::time::sleep(Duration::from_millis(10)).await;
+            output_closed.store(true, Ordering::Release);
+            output_closed_notify.notify_waiters();
+            cancellation_token.cancel();
+        }
+    });
+
+    let collected = UnifiedExecProcessManager::collect_output_until_wait_limit(
+        &output_buffer,
+        &output_notify,
+        &output_closed,
+        &output_closed_notify,
+        &cancellation_token,
+        /*pause_state*/ None,
+        OutputWaitLimit::Infinite,
+    )
+    .await;
+
+    assert!(collected.is_empty());
+}
