+#[derive(Default)]
+struct TerminalWaitRules {
+    commands: Vec<Arc<TerminalWaitCommandRule>>,
+}
+
+struct TerminalWaitCommandRule {
+    pattern: Regex,
+    cwd_pattern: Option<Regex>,
+    mode: TerminalWaitMode,
+    allow_tty: bool,
+    max_output_tokens: Option<usize>,
+}
+
+#[derive(Clone, Copy, Debug, PartialEq, Eq)]
+enum TerminalWaitMode {
+    WaitUntilExit { wait_timeout_ms: Option<u64> },
+    LongPoll { poll_interval_ms: u64 },
+}
+
+impl TerminalWaitRules {
+    fn compile(config: Option<TerminalWaitToml>) -> Self {
+        let Some(config) = config else {
+            return Self::default();
+        };
+
+        let commands = config
+            .commands
+            .into_iter()
+            .filter(|command| command.enabled)
+            .map(|command| {
+                let mode = match command.mode {
+                    TerminalWaitModeToml::WaitUntilExit => TerminalWaitMode::WaitUntilExit {
+                        wait_timeout_ms: command.wait_timeout_ms,
+                    },
+                    TerminalWaitModeToml::LongPoll => TerminalWaitMode::LongPoll {
+                        poll_interval_ms: command
+                            .poll_interval_ms
+                            .expect("long_poll config should include poll_interval_ms"),
+                    },
+                };
+                Arc::new(TerminalWaitCommandRule {
+                    pattern: Regex::new(&command.pattern)
+                        .expect("terminal_wait pattern should be validated during config load"),
+                    cwd_pattern: command.cwd_pattern.map(|pattern| {
+                        Regex::new(&pattern).expect(
+                            "terminal_wait cwd_pattern should be validated during config load",
+                        )
+                    }),
+                    mode,
+                    allow_tty: command.allow_tty,
+                    max_output_tokens: command.max_output_tokens,
+                })
+            })
+            .collect();
+
+        Self { commands }
+    }
+
+    fn matching_rule(
+        &self,
+        command: &str,
+        cwd: &str,
+        tty: bool,
+    ) -> Option<Arc<TerminalWaitCommandRule>> {
+        self.commands.iter().find_map(|rule| {
+            if tty && !rule.allow_tty {
+                return None;
+            }
+            if !rule.pattern.is_match(command) {
+                return None;
+            }
+            if let Some(cwd_pattern) = rule.cwd_pattern.as_ref()
+                && !cwd_pattern.is_match(cwd)
+            {
+                return None;
+            }
+            Some(Arc::clone(rule))
+        })
+    }
+}
